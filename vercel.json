{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(self), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ],
  "redirects": [
    { "source": "/index", "destination": "/", "statusCode": 301 },
    { "source": "/awareness", "destination": "/werkstatt-software", "statusCode": 301 },
    { "source": "/consideration", "destination": "/funktionen", "statusCode": 301 },
    { "source": "/decision", "destination": "/kostenlos-testen", "statusCode": 301 },
    { "source": "/contact-3", "destination": "/kontakt", "statusCode": 301 },
    { "source": "/lösungen", "destination": "/loesungen", "statusCode": 301 },
    { "source": "/l%C3%B6sungen", "destination": "/loesungen", "statusCode": 301 },
    { "source": "/loslegen", "destination": "/kostenlos-testen", "statusCode": 301 },
    { "source": "/demo", "destination": "/kostenlos-testen", "statusCode": 301 },
    { "source": "/testen", "destination": "/kostenlos-testen", "statusCode": 301 }
  ],
  "rewrites": [
    { "source": "/s/1", "destination": "/index.html" },
    { "source": "/s/2", "destination": "/index.html" },
    { "source": "/s/3", "destination": "/werkstatt-software.html" },
    { "source": "/s/4", "destination": "/funktionen.html" },
    { "source": "/s/5", "destination": "/loesungen.html" },
    { "source": "/s/6", "destination": "/kostenlos-testen.html" },
    { "source": "/s/7", "destination": "/kostenlos-testen.html" },
    { "source": "/s/8", "destination": "/kostenlos-testen.html" }
  ]
}
